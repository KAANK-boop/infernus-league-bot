// STANDINGS
async function loadStandings() {
  const c = document.getElementById('standingsContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const mr = await fetch('/api/admin/matches');
    const md = await mr.json();
    const ms = md.matches || [];
    const teams = {};
    ms.forEach(m => {
      if (m.status !== 'bitti' && m.status !== 'finished') return;
      const name = m.name || 'İsimsiz';
      if (!teams[name]) teams[name] = { O:0, G:0, B:0, M:0, A:0, Y:0, P:0 };
      const t = teams[name];
      t.O++;
      const gs = m.goals||[];
      const gol = gs.length;
      t.A += gol; t.Y += 0;
      if (gol > 0) t.G++; else if (gol === 0) t.B++;
      t.P = t.G * 3 + t.B;
    });
    const sorted = Object.keys(teams).sort((a,b) => {
      if (teams[b].P !== teams[a].P) return teams[b].P - teams[a].P;
      const gdA = teams[a].A - teams[a].Y, gdB = teams[b].A - teams[b].Y;
      return gdB - gdA;
    });
    if (!sorted.length) { c.innerHTML = '<div class="empty-state"><div class="icon">📋</div><p>Henüz maç verisi yok.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>#</th><th>Takım</th><th>O</th><th>G</th><th>B</th><th>M</th><th>A</th><th>Y</th><th>AV</th><th>P</th></tr></thead><tbody>';
    sorted.forEach((name, i) => {
      const t = teams[name];
      html += '<tr><td style="font-weight:700">'+(i+1)+'.</td><td style="font-weight:600">'+esc(name)+'</td><td>'+t.O+'</td><td class="num-g">'+t.G+'</td><td class="num-y">'+t.B+'</td><td class="num-r">'+t.M+'</td><td class="num-b">'+t.A+'</td><td>'+t.Y+'</td><td class="num-p">'+(t.A-t.Y)+'</td><td style="font-weight:700;font-size:15px" class="num-g">'+t.P+'</td></tr>';
    });
    html += '</tbody></table></div>';
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}

// FIXTURES
async function loadFixtures() {
  const c = document.getElementById('fixtureContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/admin/matches');
    const d = await r.json();
    const ms = d.matches || [];
    if (!ms.length) { c.innerHTML = '<div class="empty-state"><div class="icon">📅</div><p>Maç bulunamadı.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>İsim</th><th>Durum</th><th>Skor</th><th>Tarih</th></tr></thead><tbody>';
    const sorted = ms.sort((a,b) => (b.startTime||0) - (a.startTime||0));
    sorted.forEach(m => {
      const gs = m.goals||[];
      const st = m.status === 'devam' ? '<span style="color:#4ade80;font-weight:600">● Devam</span>' : '<span style="color:#94a3b8">● Bitti</span>';
      html += '<tr><td style="font-weight:600">'+esc(m.name||'İsimsiz')+'</td><td>'+st+'</td><td class="num-y">'+(m.skor||(gs.length+' - 0'))+'</td><td style="font-size:11px;color:#94a3b8">'+fmtDate(m.startTime)+'</td></tr>';
    });
    html += '</tbody></table></div><div style="color:#475569;font-size:11px;margin-top:8px">'+ms.length+' maç</div>';
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}

// LIVE REFRESH
async function leaveGuild(id, name) {
  if (!confirm(`"${name}" sunucusundan çıkılsın mı?`)) return;
  const btn = document.querySelector(`.leave-guild-btn[data-id="${id}"]`);
  if (btn) { btn.disabled = true; btn.textContent = 'Çıkılıyor...'; }
  const r = await fetch('/api/admin/guild-leave', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({guildId:id}) });
  const d = await r.json();
  if (d.ok) { toast('Sunucudan çıkıldı: ' + (d.name||name)); setTimeout(() => refresh(), 1000); }
  else { toast('Hata: ' + (d.error||'Bilinmeyen'), true); if (btn) { btn.disabled = false; btn.textContent = 'Sunucuyu At'; } }
}
async function refresh() {
  try {
    const r = await fetch('/api/status');
    const d = await r.json();
    document.getElementById('statusDot').className = 'dot ' + d.status;
    document.getElementById('statusText').textContent = d.status.charAt(0).toUpperCase() + d.status.slice(1);
    document.getElementById('s-guilds').textContent = d.guilds;
    document.getElementById('s-members').textContent = d.members;
    document.getElementById('s-ping').textContent = d.ping + 'ms';
    document.getElementById('s-cmds').textContent = d.commands;
    const u = d.uptime || 0;
    document.getElementById('s-uptime').textContent = u > 0 ? Math.floor(u/86400)+'g '+Math.floor((u%86400)/3600)+'s '+Math.floor((u%3600)/60)+'d' : '—';
    document.getElementById('startBtn').disabled = ['online','starting'].includes(d.status);
    document.getElementById('stopBtn').disabled = ['offline','stopping'].includes(d.status);
    document.getElementById('restartBtn').disabled = ['offline','stopping','starting'].includes(d.status);
    if (d.logs && d.logs.length) {
      document.getElementById('logContainer').innerHTML = d.logs.map(l => { const c = l.includes('[HATA]')?'err':''; return '<div class="l '+c+'"><span class="t">▸</span>'+esc(l)+'</div>'; }).join('');
    }
  } catch {}
}
async function act(e) { await fetch(e,{method:'POST'}); await new Promise(r => setTimeout(r,1200)); refresh(); }
document.getElementById('startBtn')?.addEventListener('click', () => act('/api/bot/start'));
document.getElementById('stopBtn')?.addEventListener('click', () => act('/api/bot/stop'));
document.getElementById('restartBtn')?.addEventListener('click', () => act('/api/bot/restart'));
setInterval(refresh, 5000);
refresh();

// HELPERS
function fmt(n) { return (n===undefined||n===null) ? '0' : n.toLocaleString('tr'); }
function fmtDate(d) { if (!d) return '—'; try { return new Date(d).toLocaleString('tr'); } catch { return d; } }
function esc(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
function toast(msg, isErr) { showToast(msg, isErr ? 'err' : 'ok'); }
function showToast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.className = 'toast ' + type; el.style.display = 'block';
  clearTimeout(el._t); el._t = setTimeout(() => el.style.display = 'none', 3000);
}
