    <!-- STATS -->
    <div class="page" id="page-stats">
      <div class="page-hdr"><div class="lft"><div class="pi">📊</div><div><h1>İstatistikler</h1><div class="sub">Bot genel kullanım ve sistem durumu</div></div></div></div>
      <div class="stats" id="statsGrid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr))">
        <div class="stat"><div class="lbl">Yükleniyor...</div></div>
