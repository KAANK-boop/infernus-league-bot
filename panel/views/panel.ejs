async function loadTrivia() {
  const c = document.getElementById('triviaContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/admin/trivia');
    const d = await r.json();
    const ts = d.trivia||[];
    if (!ts.length) { c.innerHTML = '<div class="empty-state"><div class="icon">🧠</div><p>Trivia bulunamadı.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>Soru #</th><th>Ödül</th><th>Durum</th><th>Cevap</th></tr></thead><tbody>';
    ts.forEach(t => {
      const st = t.cevaplandi ? '<span style="color:#4ade80;font-weight:600">✓ Cevaplandı</span>' : '<span style="color:#fbbf24">● Bekliyor</span>';
      html += '<tr><td>#'+t.idx+'</td><td class="num-y">'+fmt(t.odul)+'</td><td>'+st+'</td><td>'+(t.dogruCevap||'<span style="color:#4b5563">—</span>')+'</td></tr>';
    });
    html += '</tbody></table></div>';
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}

