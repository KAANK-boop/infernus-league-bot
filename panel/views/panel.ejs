    if (!hist.length) { c.innerHTML = '<div class="empty-state"><div class="icon">📝</div><p>Bu sunucuda kayıt geçmişi yok.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>Kullanıcı</th><th>Kayıtlı İsim</th><th>Rol</th><th>Kayıt Eden</th><th>Tarih</th></tr></thead><tbody>';
    hist.forEach(h => {
