// USERS
async function searchUser() {
  const id = document.getElementById('userSearch').value.trim();
  if (!id) { showToast('❌ Kullanıcı ID girin','err'); return; }
  const d = document.getElementById('userDetail'); const w = document.getElementById('userWarns');
  d.style.display='block'; d.innerHTML='<div style="color:#475569"><div class="spinner"></div></div>'; w.style.display='none';
  try {
    const r = await fetch('/api/admin/user?userId='+id);
    const j = await r.json();
    if (j.error) { d.innerHTML='<div style="color:#fca5a5">Kullanıcı bulunamadı</div>'; return; }
    const u = j.user;
    let nm = u.name;
    const isB = u.role && u.role.toLowerCase() === 'baskan';
    let html = '<div class="srow" style="padding:0 0 14px;border-bottom:1px solid rgba(255,255,255,0.04);border-bottom-style:solid"><div style="display:flex;align-items:center;gap:10px"><div style="width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#a855f7,#d946ef);display:flex;align-items:center;justify-content:center;font-size:18px">👤</div><div><div style="font-weight:600;font-size:14px">'+esc(nm||'Kayıtsız')+'</div><div class="mono" style="color:#475569;font-size:11px">'+id+'</div></div></div></div><div class="ud-grid"><div class="ud-item"><div class="ud-lbl">Bakiye</div><div class="ud-val num-g">'+fmt(u.balance)+'</div></div><div class="ud-item"><div class="ud-lbl">Banka</div><div class="ud-val num-b">'+fmt(u.bankBalance)+'</div></div>'+(isB?'':'<div class="ud-item"><div class="ud-lbl">Değer</div><div class="ud-val num-y">'+fmt(u.value)+'</div></div><div class="ud-item"><div class="ud-lbl">Gol / Asist</div><div class="ud-val">'+(u.goals||0)+' / '+(u.assists||0)+'</div></div><div class="ud-item"><div class="ud-lbl">Mevki</div><div class="ud-val">'+(u.position||'—')+'</div></div><div class="ud-item"><div class="ud-lbl">Ülke</div><div class="ud-val">'+(u.country||'—')+'</div></div>')+'<div class="ud-item"><div class="ud-lbl">Takım</div><div class="ud-val">'+(u.squad||'—')+'</div></div></div><div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap"><button class="btn '+(j.blacklisted?'btn-r':'btn-g')+' btn-sm" onclick="toggleBL(\''+id+'\','+j.blacklisted+')">'+(j.blacklisted?'Karalisteden Çıkar':'Karalisteye Ekle')+'</button><button class="btn btn-y btn-sm" onclick="showWarn(\''+id+'\')">Uyarı Ver</button><button class="btn btn-s btn-sm" onclick="viewWarns(\''+id+'\')">Uyarılar ('+(j.warns||[]).length+')</button></div>';
    if (j.blacklisted) html += '<div style="margin-top:8px;padding:8px 12px;background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.1);border-radius:6px;font-size:11px;color:#fca5a5">Bu kullanıcı karalistededir.</div>';
    d.innerHTML = html;
  } catch { d.innerHTML = '<div style="color:#fca5a5">Bağlantı hatası</div>'; }
}

async function toggleBL(id, cur) {
  if (!confirm(cur?'Karalisteden çıkarmak istediğine emin misin?':'Karalisteye eklemek istediğine emin misin?')) return;
  try {
    const r = await fetch('/api/admin/blacklist', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({userId:id, action:cur?'remove':'add'}) });
    const d = await r.json();
    if (d.ok) { showToast('✅ ' + (cur?'Karalisteden çıkarıldı':'Karalisteye eklendi'), 'ok'); searchUser(); }
    else showToast('❌ Hata', 'err');
  } catch { showToast('❌ Bağlantı hatası', 'err'); }
}

function showWarn(id) {
  const ov = document.createElement('div'); ov.className = 'modal-overlay';
  ov.innerHTML = '<div class="modal"><h2>⚠️ Uyarı Ver</h2><label>Sebep</label><input id="warnReason" placeholder="Uyarı sebebi..."><div class="mtns"><button class="btn btn-y" onclick="addWarn(\''+id+'\')">Uyar</button><button class="btn btn-r" onclick="this.closest(\'.modal-overlay\').remove()">İptal</button></div></div>';
  document.body.appendChild(ov);
}

async function addWarn(id) {
  const reason = document.getElementById('warnReason').value.trim();
  if (!reason) { showToast('❌ Sebep girin', 'err'); return; }
  try {
    const r = await fetch('/api/admin/warn', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({userId:id, reason}) });
    const d = await r.json();
    if (d.ok) { showToast('✅ Uyarı verildi', 'ok'); document.querySelector('.modal-overlay')?.remove(); searchUser(); }
    else showToast('❌ Hata', 'err');
  } catch { showToast('❌ Bağlantı hatası', 'err'); }
}

async function viewWarns(id) {
  const w = document.getElementById('userWarns'); w.style.display='block'; w.innerHTML='<div style="color:#475569"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/admin/warns?userId='+id);
    const d = await r.json();
    const warns = d.warns||[];
    if (!warns.length) { w.innerHTML = '<div style="color:#4b5563;padding:10px 0">Henüz uyarı yok.</div>'; return; }
    let html = '<div style="font-weight:600;font-size:13px;margin-bottom:10px">⚠️ Uyarılar ('+warns.length+')</div>';
    warns.forEach(ww => {
      html += '<div style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.03);font-size:12px"><div style="color:#94a3b8;margin-bottom:3px">'+(ww.reason||ww.sebep||'Belirtilmemiş')+'</div><div style="color:#4b5563;font-size:10px">'+(ww.date||ww.tarih||'—')+'</div></div>';
    });
    w.innerHTML = html;
  } catch { w.innerHTML = '<div style="color:#fca5a5">Bağlantı hatası</div>'; }
}

