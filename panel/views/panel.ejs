</div>

<div id="toast" style="display:none"></div>

<script>
const SETTINGS_DEFS = {
  kufur:{label:'Küfür Koruması',desc:'Küfür içeren mesajları siler',icon:'🔞'},
  link:{label:'Link Koruması',desc:'Reklam/kötü amaçlı linkleri engeller',icon:'🔗'},
  reklam:{label:'Reklam Koruması',desc:'Discord davet linklerini engeller',icon:'📢'},
  caps:{label:'Büyük Harf Koruması',desc:'%70\'den fazla büyük harf içeren mesajları siler',icon:'🔠'},
  flood:{label:'Flood Koruması',desc:'4 saniyede 4\'ten fazla mesajı engeller',icon:'🌊'},
  mention:{label:'Etiket Koruması',desc:'5\'ten fazla etiket içeren mesajları siler',icon:'@'},
  resim:{label:'Resim Koruması',desc:'Resim gönderimini kısıtlar',icon:'🖼️'},
  antiNuke:{label:'Anti-Nuke',desc:'Toplu kanal/rol silme işlemlerini engeller',icon:'☢️'},
  antiKanal:{label:'Kanal Koruması',desc:'Kanal silme işlemlerini engeller',icon:'#️⃣'},
  antiRol:{label:'Rol Koruması',desc:'Rol silme işlemlerini engeller',icon:'🎭'},
  antiBan:{label:'Ban Koruması',desc:'Yetkili ban işlemlerini engeller',icon:'🔨'},
  antiBot:{label:'Bot Koruması',desc:'Yeni bot eklenmesini engeller',icon:'🤖'},
  antiWebhook:{label:'Webhook Koruması',desc:'Webhook oluşturulmasını engeller',icon:'🔗'},
};
const PAGES = ['dashboard','servers','settings','economy','users','players','matches','inventory','guild-config','invites','stats','tournaments','rpg','training','giveaways','trivia','snipe','registration','squads','market','backup','standings','fixtures','music','gallery'];

function toggleCat(el) {
  const a = el.querySelector('.arr');
  const n = el.nextElementSibling;
  if (!n||!n.classList.contains('sec-items')) return;
  n.classList.toggle('open');
  if (a) a.classList.toggle('open');
}

function nav(page) {
  document.querySelectorAll('.sidebar a[data-page]').forEach(x => x.classList.remove('active'));
  const link = document.querySelector(`.sidebar a[data-page="${page}"]`);
  if (link) {
    link.classList.add('active');
    let p = link.parentElement;
    if (p && p.classList.contains('sec-items') && !p.classList.contains('open')) {
      p.classList.add('open');
      const prev = p.previousElementSibling;
      if (prev && prev.classList.contains('sec')) {
        const arr = prev.querySelector('.arr');
        if (arr) arr.classList.add('open');
      }
    }
  }
  document.querySelectorAll('.page').forEach(x => x.classList.remove('active'));
  const pg = document.getElementById('page-' + page);
  if (pg) pg.classList.add('active');
  if (page === 'economy') loadEconomy();
  if (page === 'players') loadPlayers();
  if (page === 'matches') loadMatches();
  if (page === 'settings') { const s = document.getElementById('guildSelect'); if (s.value) loadSettings(s.value); }
  if (page === 'guild-config') { const s = document.getElementById('gcfgSelect'); if (s.value) loadGuildConfig(s.value); }
  if (page === 'invites') { const s = document.getElementById('invSelect'); if (s.value) loadInvites(s.value); }
  if (page === 'inventory') { const s = document.getElementById('invGuildSelect'); if (s.value) loadInventory(s.value); }
  if (page === 'stats') loadStats();
  if (page === 'tournaments') loadTournaments();
  if (page === 'rpg') loadRpg();
  if (page === 'training') loadTraining();
  if (page === 'giveaways') loadGiveaways();
  if (page === 'trivia') loadTrivia();
  if (page === 'snipe') { const s = document.getElementById('snipeGuildSelect'); if (s.value) loadSnipe(s.value); }
  if (page === 'registration') { const s = document.getElementById('regGuildSelect'); if (s.value) loadRegistration(s.value); }
  if (page === 'squads') loadSquads();
  if (page === 'market') { const s = document.getElementById('mktGuildSelect'); if (s.value) loadMarket(s.value); }
  if (page === 'backup') loadBackup();
  if (page === 'dashboard') loadDashboardData();
  if (page === 'standings') loadStandings();
  if (page === 'fixtures') loadFixtures();
}

document.querySelectorAll('.sidebar a[data-page]').forEach(a => {
  a.addEventListener('click', function(e) {
    e.preventDefault();
    const p = this.dataset.page;
    history.pushState(null, '', '#' + p);
    nav(p);
  });
});
window.addEventListener('hashchange', () => {
  const p = location.hash.replace('#','') || 'dashboard';
  if (PAGES.includes(p)) nav(p);
});
(function() {
  const p = location.hash.replace('#','') || 'dashboard';
  nav(p);
})();

document.getElementById('guildSelect')?.addEventListener('change', function() {
  if (this.value) loadSettings(this.value); else document.getElementById('settingsContainer').innerHTML = '<div style="color:#475569;padding:40px;text-align:center;grid-column:1/-1">Lütfen bir sunucu seçin.</div>';
});
document.getElementById('invSelect')?.addEventListener('change', function() {
  if (this.value) loadInvites(this.value); else document.getElementById('invContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>';
});
document.getElementById('gcfgSelect')?.addEventListener('change', function() {
  if (this.value) loadGuildConfig(this.value); else document.getElementById('gcfgContainer').innerHTML = '<div style="color:#475569;padding:40px;text-align:center;grid-column:1/-1">Lütfen bir sunucu seçin.</div>';
});
document.getElementById('invGuildSelect')?.addEventListener('change', function() {
  if (this.value) loadInventory(this.value); else { document.getElementById('vehicleContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>'; document.getElementById('houseContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>'; }
});
document.getElementById('snipeGuildSelect')?.addEventListener('change', function() {
  if (this.value) loadSnipe(this.value); else document.getElementById('snipeContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>';
});
document.getElementById('regGuildSelect')?.addEventListener('change', function() {
  if (this.value) loadRegistration(this.value); else document.getElementById('regContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>';
});
document.getElementById('mktGuildSelect')?.addEventListener('change', function() {
  if (this.value) loadMarket(this.value); else { document.getElementById('mktVehicleContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>'; document.getElementById('mktHouseContainer').innerHTML = '<div style="color:#475569;padding:20px;text-align:center">Bir sunucu seçin.</div>'; }
});

// SETTINGS
async function loadSettings(id) {
  const c = document.getElementById('settingsContainer');
  c.innerHTML = '<div style="color:#475569;padding:40px;text-align:center;grid-column:1/-1"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/settings?guildId=' + id);
    const d = await r.json();
    if (d.error) { c.innerHTML = '<div style="color:#fca5a5;padding:40px;text-align:center">Hata</div>'; return; }
    renderSettings(d.settings, id);
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:40px;text-align:center">Bağlantı hatası</div>'; }
}

function renderSettings(settings, id) {
  let html = '<div class="settings-card"><div class="shdr"><h3>📝 Log</h3></div><div class="srow"><div class="info"><div class="n">Log Kanalı ID</div><div class="d">Koruma loglarının gönderileceği kanal</div></div><input class="setting-input" id="logKanalInput" value="' + esc(settings.logKanal||'') + '" placeholder="Kanal ID"><button class="btn btn-g btn-xs" style="margin-left:6px" onclick="saveSetting(\''+id+'\',\'logKanal\',document.getElementById(\'logKanalInput\').value||null)">Kaydet</button></div></div>';
  html += '<div class="settings-card"><div class="shdr"><h3>👮 Whitelist</h3></div><div class="srow"><div class="info"><div class="n">Yetkili ID\'leri</div><div class="d">Virgülle ayırın (123,456)</div></div><input class="setting-input" id="wlInput" value="'+((settings.whitelist||[]).join(','))+'" placeholder="ID,ID,ID"><button class="btn btn-g btn-xs" style="margin-left:6px" onclick="saveWhitelist(\''+id+'\')">Kaydet</button></div></div>';
  html += '<div class="settings-card"><div class="shdr"><h3>🛡️ Mesaj Korumaları</h3></div>';
  ['kufur','link','reklam','caps','flood','mention','resim'].forEach(k => {
    const s = SETTINGS_DEFS[k];
    const v = settings[k]?.enabled !== undefined ? settings[k].enabled : !!settings[k];
    html += '<div class="srow"><div class="info"><div class="n">' + s.icon + ' ' + s.label + '</div><div class="d">' + s.desc + '</div></div><div class="toggle ' + (v?'on':'') + '" onclick="toggleSetting(\''+id+'\',\''+k+'\',this)"><div class="knob"></div></div></div>';
  });
  html += '</div><div class="settings-card"><div class="shdr"><h3>☢️ Sunucu Korumaları</h3></div>';
  ['antiNuke','antiKanal','antiRol','antiBan','antiBot','antiWebhook'].forEach(k => {
    const s = SETTINGS_DEFS[k];
    const v = settings[k]?.enabled !== undefined ? settings[k].enabled : !!settings[k];
    html += '<div class="srow"><div class="info"><div class="n">' + s.icon + ' ' + s.label + '</div><div class="d">' + s.desc + '</div></div><div class="toggle ' + (v?'on':'') + '" onclick="toggleSetting(\''+id+'\',\''+k+'\',this)"><div class="knob"></div></div></div>';
  });
  html += '</div>';
  document.getElementById('settingsContainer').innerHTML = html;
}

async function toggleSetting(id, key, el) {
  const was = el.classList.contains('on');
  el.classList.toggle('on');
  try {
    const r = await fetch('/api/settings', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({guildId:id, key, value:{enabled:!was}}) });
    const d = await r.json();
    if (d.ok) showToast('✅ ' + (SETTINGS_DEFS[key]?.label||key) + ' ' + (!was?'açıldı':'kapatıldı'), 'ok');
    else { el.classList.toggle('on'); showToast('❌ Hata', 'err'); }
  } catch { el.classList.toggle('on'); showToast('❌ Bağlantı hatası', 'err'); }
}

async function saveSetting(id, key, value) {
  try {
    const r = await fetch('/api/settings', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({guildId:id, key, value}) });
    const d = await r.json();
    if (d.ok) showToast('✅ Kaydedildi', 'ok'); else showToast('❌ Hata', 'err');
  } catch { showToast('❌ Bağlantı hatası', 'err'); }
}

async function saveWhitelist(id) {
  const val = document.getElementById('wlInput').value;
  const ids = val ? val.split(',').map(s => s.trim()).filter(Boolean) : [];
  try {
    const r = await fetch('/api/settings', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({guildId:id, key:'whitelist', value:ids}) });
    const d = await r.json();
    if (d.ok) showToast('✅ Whitelist kaydedildi', 'ok'); else showToast('❌ Hata', 'err');
  } catch { showToast('❌ Bağlantı hatası', 'err'); }
}

// ECONOMY
async function loadEconomy() {
  const c = document.getElementById('ecoContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/admin/users');
    const d = await r.json();
    if (d.error) { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Hata: '+d.error+'</div>'; return; }
    let users = d.users || [];
    const q = document.getElementById('ecoSearch').value.trim().toLowerCase();
    if (q) users = users.filter(u => u.id.includes(q)||(u.name||'').toLowerCase().includes(q));
    if (!users.length) { c.innerHTML = '<div class="empty-state"><div class="icon">💸</div><p>Kullanıcı bulunamadı.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>ID</th><th>İsim</th><th>Bakiye</th><th>Banka</th><th>Toplam</th><th>Değer</th><th>Mevki</th><th>Takım</th><th></th></tr></thead><tbody>';
    users.forEach(u => {
      const t = (u.balance||0)+(u.bankBalance||0);
      const isB = u.role && u.role.toLowerCase() === 'baskan';
      const valCell = isB ? '<td style="color:#4b5563">—</td>' : '<td class="num-y">'+fmt(u.value)+'</td>';
      const posCell = isB ? '<td style="color:#4b5563">—</td>' : '<td>'+(u.position||'—')+'</td>';
      html += '<tr><td class="mono">'+u.id+'</td><td>'+(u.name||'<span style="color:#4b5563">Kayıtsız</span>')+'</td><td class="num-g">'+fmt(u.balance)+'</td><td class="num-b">'+fmt(u.bankBalance)+'</td><td class="num-p">'+fmt(t)+'</td>'+valCell+posCell+'<td>'+(u.squad||'—')+'</td><td><button class="btn btn-p btn-xs" onclick="editEco(\''+u.id+'\',\''+esc(u.name||u.id)+'\','+(u.balance||0)+','+(u.bankBalance||0)+')">✏️</button></td></tr>';
    });
    html += '</tbody></table></div><div style="color:#475569;font-size:11px;margin-top:8px">'+users.length+' kullanıcı</div>';
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}

function editEco(id, name, bal, bank) {
  const ov = document.createElement('div'); ov.className = 'modal-overlay';
  ov.innerHTML = '<div class="modal"><h2>💰 ' + name + '</h2><label>Bakiye</label><input id="ecoBal" value="'+bal+'"><label>Banka</label><input id="ecoBank" value="'+bank+'"><div class="mtns"><button class="btn btn-p" onclick="saveEco(\''+id+'\')">Kaydet</button><button class="btn btn-r" onclick="this.closest(\'.modal-overlay\').remove()">İptal</button></div></div>';
  document.body.appendChild(ov);
}

async function saveEco(id) {
  const bal = parseInt(document.getElementById('ecoBal').value)||0;
  const bank = parseInt(document.getElementById('ecoBank').value)||0;
  await fetch('/api/admin/user-update',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({userId:id,key:'balance',value:bal})});
  await fetch('/api/admin/user-update',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({userId:id,key:'bankBalance',value:bank})});
  showToast('✅ Bakiye güncellendi','ok');
  document.querySelector('.modal-overlay')?.remove();
  loadEconomy();
}

// PLAYERS
async function loadPlayers() {
  const c = document.getElementById('plContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const search = document.getElementById('plSearch').value.trim();
    const sort = document.getElementById('plSort').value;
    const order = document.getElementById('plOrder').value;
    const r = await fetch('/api/admin/players?search='+encodeURIComponent(search)+'&sort='+sort+'&order='+order);
    const d = await r.json();
    if (d.error) { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Hata: '+d.error+'</div>'; return; }
    const pl = d.players || [];
    if (!pl.length) { c.innerHTML = '<div class="empty-state"><div class="icon">⚽</div><p>Oyuncu bulunamadı.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>#</th><th>İsim</th><th>Değer</th><th>Gol</th><th>Asist</th><th>Bakiye</th><th>Mevki</th><th>Takım</th><th>Skills</th></tr></thead><tbody>';
    pl.forEach((p,i) => {
      const isB = p.role && p.role.toLowerCase() === 'baskan';
      const sk = p.skills || {};
      const skStr = 'G:'+(sk.genel||50)+' H:'+(sk.hiz||50)+' Ş:'+(sk.sut||50);
      const valCell = isB ? '<td style="color:#4b5563">—</td>' : '<td class="num-y">'+fmt(p.value)+'M</td>';
      const gCell = isB ? '<td style="color:#4b5563">—</td>' : '<td class="num-g">'+p.goals+'</td>';
      const aCell = isB ? '<td style="color:#4b5563">—</td>' : '<td class="num-b">'+p.assists+'</td>';
      const posCell = isB ? '<td style="color:#4b5563">—</td>' : '<td>'+(p.position||'—')+'</td>';
      const skCell = isB ? '<td style="color:#4b5563">—</td>' : '<td style="font-size:10px;color:#94a3b8">'+skStr+'</td>';
      html += '<tr><td>'+(i+1)+'</td><td>'+(p.name||'<span style="color:#4b5563">Kayıtsız</span>')+'</td>'+valCell+gCell+aCell+'<td class="num-p">'+fmt(p.balance)+'</td>'+posCell+'<td>'+(p.squad||'—')+'</td>'+skCell+'</tr>';
    });
    html += '</tbody></table></div><div style="color:#475569;font-size:11px;margin-top:8px">'+d.total+' oyuncu (gösterilen: '+pl.length+')</div>';
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}

// MATCHES
async function loadMatches() {
  const c = document.getElementById('matchContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/admin/matches');
    const d = await r.json();
    const ms = d.matches || [];
    if (!ms.length) { c.innerHTML = '<div class="empty-state"><div class="icon">🏟️</div><p>Maç bulunamadı.</p></div>'; return; }
    let html = '<div class="table-wrap"><table class="mtable"><thead><tr><th>ID</th><th>İsim</th><th>Durum</th><th>Skor</th><th>Gol Sayısı</th><th>Başlangıç</th><th></th></tr></thead><tbody>';
    ms.forEach(m => {
      const gs = m.goals||[];
      const status = m.status === 'devam' ? '<span style="color:#4ade80;font-weight:600">● Devam</span>' : '<span style="color:#94a3b8">● Bitti</span>';
      const skor = m.skor || (gs.length+' - 0');
      html += '<tr><td class="mono">'+m.id+'</td><td>'+esc(m.name||'İsimsiz Maç')+'</td><td>'+status+'</td><td class="num-y">'+skor+'</td><td>'+gs.length+'</td><td style="font-size:11px;color:#94a3b8">'+fmtDate(m.startTime)+'</td><td><button class="btn btn-s btn-xs" onclick="toggleMatchDetail(this,\''+m.id+'\')">📋</button></td></tr>';
      html += '<tr id="md-'+m.id+'" style="display:none"><td colspan="7"><div style="padding:10px;font-size:12px">';
      if (gs.length) {
        html += '<div style="font-weight:600;margin-bottom:6px;color:#a855f7">Goller:</div>';
        gs.forEach(g => { html += '<div style="padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.03)">⚽ '+(g.dk||'?')+'\' — '+(g.userName||g.player||g.userId||'?')+'</div>'; });
      } else { html += '<div style="color:#475569">Henüz gol yok.</div>'; }
      html += '<div style="margin-top:8px;color:#475569;font-size:10px">Kanal: '+(m.channelId||'—')+'</div>';
      if (m.endTime) html += '<div style="color:#475569;font-size:10px">Bitiş: '+fmtDate(m.endTime)+'</div>';
      html += '</div></td></tr>';
    });
    html += '</tbody></table></div>';
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}
function toggleMatchDetail(btn, id) {
