    document.getElementById('statsDetail').innerHTML = '<div class="table-wrap"><table class="mtable"><thead><tr><th>Metric</th><th>Değer</th></tr></thead><tbody><tr><td>Sunucular</td><td class="num-p">'+fmt(d.guildCount)+'</td></tr><tr><td>Kullanıcılar</td><td class="num-p">'+fmt(d.memberCount)+'</td></tr><tr><td>Komutlar</td><td class="num-p">'+fmt(d.commands)+'</td></tr><tr><td>Toplam Maç</td><td class="num-p">'+fmt(d.totalMatches)+'</td></tr><tr><td>Uptime</td><td class="num-p">'+fmtUptime(d.uptime)+'</td></tr></tbody></table></div>';
  } catch { g.innerHTML = '<div style="color:#fca5a5;padding:20px">Bağlantı hatası</div>'; }
}
function fmtUptime(s) {
  if (!s) return '—';
  const d = Math.floor(s/86400), h = Math.floor((s%86400)/3600), m = Math.floor((s%3600)/60);
  return (d>0?d+'g ':'')+(h>0?h+'s ':'')+m+'d';
}

