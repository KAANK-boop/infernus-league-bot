// SQUADS
async function loadSquads() {
  const c = document.getElementById('squadContainer');
  c.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const r = await fetch('/api/admin/players?sort=name&order=asc');
    const d = await r.json();
    const pl = d.players||[];
    const teams = {};
    pl.forEach(p => {
      const t = p.squad || 'Takımsız';
      if (!teams[t]) teams[t] = [];
      teams[t].push(p);
    });
    const sorted = Object.keys(teams).sort((a,b) => {
      if (a === 'Takımsız') return 1;
      if (b === 'Takımsız') return -1;
      return teams[b].length - teams[a].length;
    });
    if (!sorted.length) { c.innerHTML = '<div class="empty-state"><div class="icon">👥</div><p>Oyuncu bulunamadı.</p></div>'; return; }
    let html = '';
    sorted.forEach(t => {
      const members = teams[t];
      html += '<div class="card" style="margin-bottom:14px;padding:16px 20px"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px"><span style="font-weight:700;font-size:14px">'+(t==='Takımsız'?'👤 Takımsız': '👥 '+esc(t))+'</span><span style="color:#6b7280;font-size:11px">'+members.length+' oyuncu</span></div><div class="table-wrap"><table class="mtable"><thead><tr><th>#</th><th>İsim</th><th>Mevki</th><th>Değer</th><th>Gol</th><th>Asist</th></tr></thead><tbody>';
      members.forEach((p,i) => {
        html += '<tr><td>'+(i+1)+'</td><td>'+(p.name||'<span style="color:#4b5563">Kayıtsız</span>')+'</td><td>'+(p.position||'—')+'</td><td class="num-y">'+fmt(p.value)+'M</td><td class="num-g">'+p.goals+'</td><td class="num-b">'+p.assists+'</td></tr>';
      });
      html += '</tbody></table></div></div>';
    });
    c.innerHTML = html;
  } catch { c.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>'; }
}

// MARKET
async function loadMarket(guildId) {
  const vc = document.getElementById('mktVehicleContainer');
  const hc = document.getElementById('mktHouseContainer');
  vc.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  hc.innerHTML = '<div style="color:#475569;padding:20px;text-align:center"><div class="spinner"></div></div>';
  try {
    const [vr, hr] = await Promise.all([
      fetch('/api/admin/vehicles?guildId='+guildId),
      fetch('/api/admin/houses?guildId='+guildId)
    ]);
    const vd = await vr.json(); const hd = await hr.json();
    const vehs = vd.vehicles || []; const hous = hd.houses || [];
    if (!vehs.length) { vc.innerHTML = '<div class="empty-state"><div class="icon">🚗</div><p>Bu sunucuda satılık araç yok.</p></div>'; }
    else {
      let h = '<div class="table-wrap"><table class="mtable"><thead><tr><th>Sahip</th><th>Tip</th><th>Model</th><th>Fiyat</th></tr></thead><tbody>';
      vehs.forEach(v => { h += '<tr><td>'+(v.userName||'<span style="color:#4b5563">Kayıtsız</span>')+'</td><td>'+esc(v.tip||'—')+'</td><td>'+esc(v.model||'—')+'</td><td class="num-y">'+fmt(v.fiyat)+' TL</td></tr>'; });
      h += '</tbody></table></div><div style="color:#475569;font-size:11px;margin-top:8px">'+vehs.length+' araç</div>';
      vc.innerHTML = h;
    }
    if (!hous.length) { hc.innerHTML = '<div class="empty-state"><div class="icon">🏡</div><p>Bu sunucuda satılık ev yok.</p></div>'; }
    else {
      let h = '<div class="table-wrap"><table class="mtable"><thead><tr><th>Sahip</th><th>İsim</th><th>Fiyat</th></tr></thead><tbody>';
      hous.forEach(ev => { h += '<tr><td>'+(ev.userName||'<span style="color:#4b5563">Kayıtsız</span>')+'</td><td>'+esc(ev.isim||'—')+'</td><td class="num-y">'+fmt(ev.fiyat)+' TL</td></tr>'; });
      h += '</tbody></table></div><div style="color:#475569;font-size:11px;margin-top:8px">'+hous.length+' ev</div>';
      hc.innerHTML = h;
    }
  } catch {
    vc.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>';
    hc.innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">Bağlantı hatası</div>';
  }
}

// BACKUP
async function loadBackup() {
  try {
    const r = await fetch('/api/admin/backup');
    const d = await r.json();
    const json = JSON.stringify(d);
    const size = new Blob([json]).size;
    const sizes = ['B','KB','MB','GB'];
    const i = Math.floor(Math.log(size)/Math.log(1024));
    const sz = (size / Math.pow(1024, i)).toFixed(1) + ' ' + sizes[i];
    document.getElementById('backupSize').textContent = sz;
    document.getElementById('backupUsers').textContent = Object.keys(d.users||{}).length;
    document.getElementById('backupKeys').textContent = Object.keys(d).length;
  } catch {}
}
function downloadBackup() {
  fetch('/api/admin/backup').then(r => r.json()).then(d => {
    const blob = new Blob([JSON.stringify(d, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'elektro-backup-' + new Date().toISOString().slice(0,10) + '.json';
    a.click();
    URL.revokeObjectURL(a.href);
    showToast('✅ Yedek indiriliyor', 'ok');
  }).catch(() => showToast('❌ Yedek alınamadı', 'err'));
}

// SERVER DETAIL
function showServerDetail(guildId, guildName) {
  const ov = document.createElement('div'); ov.className = 'modal-overlay';
  ov.innerHTML = '<div class="modal" style="max-width:600px"><h2>🖥 ' + esc(guildName) + '</h2><div style="color:#475569;text-align:center;padding:20px"><div class="spinner"></div></div><div class="mtns"><button class="btn btn-s" onclick="this.closest(\'.modal-overlay\').remove()">Kapat</button></div></div>';
  document.body.appendChild(ov);
  fetch('/api/admin/guild-detail?guildId=' + guildId).then(r => r.json()).then(d => {
    if (d.error) { ov.querySelector('.modal > div:first-of-type').innerHTML = '<div style="color:#fca5a5;padding:20px;text-align:center">' + d.error + '</div>'; return; }
    let html = '<div style="display:flex;align-items:center;gap:14px;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,0.04)">';
    if (d.icon) html += '<img src="' + d.icon + '" style="width:48px;height:48px;border-radius:12px">';
    html += '<div><div style="font-weight:700;font-size:15px">' + esc(d.name) + '</div><div class="mono" style="color:#475569;font-size:11px">' + d.id + '</div></div></div>';
    html += '<div class="ud-grid"><div class="ud-item"><div class="ud-lbl">Toplam Üye</div><div class="ud-val purple">' + d.memberCount + '</div></div><div class="ud-item"><div class="ud-lbl">İnsan</div><div class="ud-val blue">' + d.humanCount + '</div></div><div class="ud-item"><div class="ud-lbl">Bot</div><div class="ud-val green">' + d.botCount + '</div></div><div class="ud-item"><div class="ud-lbl">Sahip</div><div class="ud-val" style="font-size:13px">' + d.ownerId + '</div></div></div>';
    html += '<h3 style="font-size:13px;font-weight:700;margin:16px 0 8px">📋 Kanallar (' + (d.channels||[]).length + ')</h3><div style="max-height:140px;overflow-y:auto;font-size:11px">';
    (d.channels||[]).forEach(c => { html += '<div style="padding:4px 0;color:#94a3b8"><span class="mono">#' + esc(c.name) + '</span> <span style="color:#4b5563">(' + c.id + ')</span></div>'; });
    html += '</div><h3 style="font-size:13px;font-weight:700;margin:16px 0 8px">🎭 Roller (' + (d.roles||[]).length + ')</h3><div style="max-height:140px;overflow-y:auto;font-size:11px">';
    (d.roles||[]).forEach(r => { html += '<div style="padding:4px 0;color:#94a3b8"><span style="color:#' + r.color.toString(16).padStart(6,'0') + '">●</span> ' + esc(r.name) + ' <span style="color:#4b5563">(' + r.memberCount + ' üye)</span></div>'; });
    html += '</div>';
    const container = ov.querySelector('.modal > div');
    if (container) container.outerHTML = html;
  }).catch(() => { const c = ov.querySelector('.modal > div'); if (c) c.innerHTML = '<div style="color:#fca5a5;text-align:center">Bağlantı hatası</div>'; });
}

// DASHBOARD DATA
async function loadDashboardData() {
  try {
    const [balR, valR] = await Promise.all([
      fetch('/api/admin/top-users?type=balance&limit=5'),
      fetch('/api/admin/top-users?type=value&limit=5')
    ]);
    const bal = await balR.json(); const val = await valR.json();
