<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elektro Lig - Komutlar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',sans-serif;background:#030305;color:#fff;overflow-x:hidden}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:#030305}::-webkit-scrollbar-thumb{background:#1a1a2e;border-radius:3px}
a{text-decoration:none;color:inherit}
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:14px 40px;display:flex;align-items:center;justify-content:space-between;background:rgba(3,3,5,0.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.04)}
nav .brand{display:flex;align-items:center;gap:10px}
nav .brand h2{font-size:18px;font-weight:800;letter-spacing:-0.5px}
nav .brand h2 span{background:linear-gradient(135deg,#a855f7,#d946ef);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
nav .brand .prefix{font-size:9px;color:#4b5563;background:rgba(255,255,255,0.04);padding:2px 8px;border-radius:4px;letter-spacing:1px;text-transform:uppercase}
nav .links{display:flex;align-items:center;gap:24px}
nav .links a{color:#6b7280;font-size:13px;font-weight:500;transition:color .2s}
nav .links a:hover{color:#fff}
.container{max-width:1100px;margin:0 auto;padding:100px 20px 60px}
.page-header{margin-bottom:36px}
.page-header h1{font-size:28px;font-weight:800;letter-spacing:-0.5px;margin-bottom:6px}
.page-header .sub{color:#6b7280;font-size:14px}
.page-header .sub code{background:rgba(168,85,247,0.1);color:#c084fc;padding:2px 8px;border-radius:4px;font-size:12px}
.cmd-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px}
.cmd-cat{background:linear-gradient(135deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.04);border-radius:14px;padding:20px;transition:border-color .3s}
.cmd-cat:hover{border-color:rgba(168,85,247,0.12)}
.cmd-cat .cat-header{font-size:15px;font-weight:600;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;gap:8px}
.cmd-cat .cmd-item{padding:5px 0;color:#9ca3af;font-size:12px;font-family:'Monaco','Cascadia Code',monospace}
.cmd-cat .cmd-item::before{content:'▸';color:#4b5563;margin-right:8px;font-size:10px}
.back-link{display:inline-block;margin-top:32px;color:#6b7280;font-size:13px;transition:color .2s}
.back-link:hover{color:#d1d5db}
@media(max-width:700px){
  nav{padding:12px 16px}
  nav .links a{font-size:11px;display:none}
  .container{padding:80px 16px 40px}
  .cmd-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>
<nav>
  <div class="brand">
    <h2>⚡<span>Elektro</span></h2>
    <span class="prefix">.</span>
  </div>
  <div class="links">
    <a href="/">Ana Sayfa</a>
    <a href="/login" style="background:linear-gradient(135deg,#a855f7,#d946ef);padding:8px 18px;border-radius:8px;color:#fff!important;font-weight:600;font-size:12px">Panel</a>
  </div>
</nav>
<div class="container">
  <div class="page-header">
    <h1>📋 Komutlar</h1>
    <div class="sub">Tüm komutlar <code>.</code> prefix'i ile kullanılır</div>
  </div>
  <div class="cmd-grid">
    <% categories.forEach(c => { %>
    <div class="cmd-cat">
      <div class="cat-header"><span><%= c.icon %></span><%= c.name %></div>
      <% c.cmds.forEach(cmd => { %><div class="cmd-item"><%= cmd %></div><% }) %>
    </div>
    <% }) %>
  </div>
  <a href="/" class="back-link">← Ana Sayfaya Dön</a>
</div>
</body>
</html>
